# === Required ===
OPENAI_API_KEY=sk-your-key-here

# === Optional: Speaker Diarization ===
# Get a free key at https://www.assemblyai.com (100 hours free)
ASSEMBLYAI_API_KEY=

# === Optional: Cloud Sync ===
SYNC_KEY=

# === Cloud Auth: Twilio Verify (SMS OTP) ===
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# === Resend: email OTP + recap delivery + (Plus) custom-domain sending ===
RESEND_API_KEY=
RESEND_FROM=VideoScriber <auth@videoscriber.ai>

# === Cloud Auth: hashing + cookie options ===
# 32+ char random string; used to HMAC OTP codes at rest
OTP_HASH_KEY=
# Set to "false" only for local http dev; prod should always be true
AUTH_COOKIE_SECURE=true
# Set to "true" to bypass real SMS/email. Any phone accepts code 000000.
AUTH_DEV_BYPASS=false
# Primary auth channel. "sms" = phone OTP (production, requires A2P 10DLC).
# "email" = email OTP via Resend (temporary while A2P pending).
AUTH_MODE=sms

# === Server ===
HOST=127.0.0.1
PORT=8000
MAX_UPLOAD_MB=1000
MAX_CONCURRENT_JOBS=2

# === Freemium plan limits (cloud only; desktop is unmetered) ===
FREE_MAX_FILE_MB=250
FREE_MONTHLY_LIMIT=3
PLUS_MAX_FILE_MB=1024
# Free-tier transcripts auto-delete after this many days
FREE_RETENTION_DAYS=10
# How long to wait for in-flight transcriptions when shutting down
GRACEFUL_SHUTDOWN_S=60

# === Stripe (billing) ===
# Test keys from https://dashboard.stripe.com/test/apikeys (cloud only; desktop is BYO-keys)
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# Recurring price IDs created in Stripe dashboard (one product, two prices)
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=
# Signing secret from `stripe listen` (local dev) or dashboard endpoint (deployed)
STRIPE_WEBHOOK_SECRET=
# Where Checkout + Portal redirect after pay / cancel — overridden per environment
STRIPE_SUCCESS_URL=http://127.0.0.1:8000/app?upgraded=1
STRIPE_CANCEL_URL=http://127.0.0.1:8000/upgrade?status=canceled
STRIPE_PORTAL_RETURN_URL=http://127.0.0.1:8000/app

# === AI Models ===
RECAP_MODEL=gpt-4o-mini
# Embedding model used by the AI Assistant's library search. Override if your
# OpenAI project doesn't have access to text-embedding-3-small.
EMBEDDING_MODEL=text-embedding-3-small

# === Video ===
KEEP_VIDEO_FOR_PREVIEW=true
# Auto-delete uploaded videos after N days (0 = never)
VIDEO_RETENTION_DAYS=90

# === Integrations (Zoom, Google Meet, local folder) ===
# Required once integrations are connected — encrypts OAuth tokens at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
INTEGRATIONS_TOKEN_KEY=
# Zoom OAuth — create a Marketplace app at https://marketplace.zoom.us
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_REDIRECT_URI=http://127.0.0.1:8000/api/integrations/zoom/oauth/callback
# Google OAuth — create credentials at https://console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/integrations/google_meet/oauth/callback
